def correr_reglas(transacciones, etiqueta,
                  min_support=0.015, min_confidence=0.20, min_lift=1.2):
    """
    Aplica el algoritmo Apriori sobre una lista de transacciones.

    Parámetros:
        transacciones  : list[list[str]] — cada lista es un pedido
        etiqueta       : str — nombre del segmento (para log)
        min_support    : float — % mínimo de pedidos con la combinación
        min_confidence : float — P(B|A) mínima
        min_lift       : float — lift mínimo (>1 = no es azar)

    Retorna:
        DataFrame con columnas: antecedente, consecuente,
        support, confidence, lift
    """
    te      = TransactionEncoder()
    te_arr  = te.fit(transacciones).transform(transacciones)
    df_bool = pd.DataFrame(te_arr, columns=te.columns_)
    freq    = apriori(df_bool, min_support=min_support, use_colnames=True)
    if freq.empty:
        return pd.DataFrame()
    reglas = association_rules(freq, metric="lift", min_threshold=min_lift)
    reglas = reglas[reglas['confidence'] >= min_confidence].copy()
    reglas['antecedente'] = reglas['antecedents'].apply(lambda x: ', '.join(sorted(x)))
    reglas['consecuente'] = reglas['consequents'].apply(lambda x: ', '.join(sorted(x)))
    reglas = reglas.sort_values('lift', ascending=False).reset_index(drop=True)
    print(f"   [{etiqueta}] → {len(reglas)} reglas")
    return reglas


