def estilo_fila(ws, fila, cols, fg='232342'):
    for col in range(1, cols + 1):
        c = ws.cell(row=fila, column=col)
        c.fill      = PatternFill("solid", fgColor=fg)
        c.font      = Font(color='F0F0F0', size=10)
        c.alignment = Alignment(horizontal='center', vertical='center')

def borde_tabla(ws, f_ini, f_fin, c_ini, c_fin):
    thin = Side(style='thin', color='444466')
    for row in ws.iter_rows(min_row=f_ini, max_row=f_fin, min_col=c_ini, max_col=c_fin):
        for cell in row:
            cell.border = Border(left=thin, right=thin, top=thin, bottom=thin)

def titulo_seccion(ws, fila, texto, cols=6):
    ws.merge_cells(start_row=fila, start_column=1, end_row=fila, end_column=cols)
    c = ws.cell(row=fila, column=1, value=texto)
    c.fill      = PatternFill("solid", fgColor='1A1A2E')
    c.font      = Font(bold=True, color='F5A623', size=13)
    c.alignment = Alignment(horizontal='left', vertical='center')
    ws.row_dimensions[fila].height = 28


