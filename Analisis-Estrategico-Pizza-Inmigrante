def escribir_reglas(ws, reglas, fila_inicio, titulo, color_header):
    titulo_seccion(ws, fila_inicio, f'  {titulo}', 6)
    fh = fila_inicio + 1
    estilo_header(ws, fh, 6, fg=color_header)
    for j, h in enumerate(
        ['SI pide...', 'ENTONCES pide...', 'Soporte', 'Confianza', 'Lift', 'Intensidad'], 1
    ):
        ws.cell(row=fh, column=j, value=h)
    if reglas.empty:
        ws.cell(row=fh + 1, column=1, value='Sin reglas con los umbrales actuales')
        return fh + 2
    for i, (_, r) in enumerate(reglas.head(15).iterrows()):
        ro = fh + 1 + i
        intensidad = 'MUY FUERTE (lift>5)' if r['lift'] >= 5 else 'FUERTE (lift>3)' if r['lift'] >= 3 else 'MODERADO'
        ws.cell(row=ro, column=1, value=r['antecedente'])
        ws.cell(row=ro, column=2, value=r['consecuente'])
        ws.cell(row=ro, column=3, value=round(r['support'], 3))
        ws.cell(row=ro, column=4, value=f"{r['confidence']*100:.0f}%")
        ws.cell(row=ro, column=5, value=round(r['lift'], 2))
        ws.cell(row=ro, column=6, value=intensidad)
        alt = '2A2A4A' if i % 2 == 0 else '1E1E3E'
        estilo_fila(ws, ro, 6, fg=alt)
        ws.cell(row=ro, column=1).alignment = Alignment(horizontal='left')
        ws.cell(row=ro, column=2).alignment = Alignment(horizontal='left')
        col_lift = '2ECC71' if r['lift'] >= 4 else '0F9B8E' if r['lift'] >= 2.5 else 'F5A623'
        ws.cell(row=ro, column=5).font = Font(color=col_lift, bold=True, size=10)
        ws.row_dimensions[ro].height = 20
    borde_tabla(ws, fh, fh + min(15, len(reglas)), 1, 6)
    return fh + min(15, len(reglas)) + 2


